{
  "productName": "everytin",
  "version": "0.1.0",
  "identifier": "com.everytin.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "everytin",
        "width": 1300,
        "height": 840,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": ["German", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Your intelligent Windows assistant",
    "longDescription": "everytin simplifies Windows maintenance with AI-powered system management, automatic updates, and smart optimization."
  },
  "plugins": {}
}
